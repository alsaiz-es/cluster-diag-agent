#!/bin/bash
### BEGIN INIT INFO
# Provides:          css-diagnet
# Required-Start:    $network $remote_fs css-echo-server
# Required-Stop:     $network $remote_fs
# Default-Start:     2 3 4 5
# Default-Stop:      0 1 6
# Description:       DiagNet - synthetic ICMP/TCP/ECHO probes
### END INIT INFO

NAME="css-diagnet"
PIDFILE="/var/run/${NAME}.pid"
DAEMON="/opt/css_diag_agent/diagnet/diagnet.sh"

start() {
    if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
        echo "$NAME is already running."
        return 0
    fi
    echo "Starting $NAME..."
    ulimit -n 65536 2>/dev/null || true
    nohup "$DAEMON" >> /var/log/css_diag_agent/diagnet_daemon.log 2>&1 &
    echo $! > "$PIDFILE"
}

stop() {
    if [ ! -f "$PIDFILE" ] || ! kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
        echo "$NAME is not running."
        return 0
    fi
    echo "Stopping $NAME..."
    kill "$(cat "$PIDFILE")"
    rm -f "$PIDFILE"
}

status() {
    if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
        echo "$NAME running (PID $(cat "$PIDFILE"))"
    else
        echo "$NAME stopped"
        return 1
    fi
}

case "$1" in
    start)   start ;;
    stop)    stop ;;
    restart) stop; sleep 1; start ;;
    status)  status ;;
    *)       echo "Usage: $0 {start|stop|restart|status}"; exit 1 ;;
esac
